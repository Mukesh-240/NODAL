# ─── NODAL Environment Variables ─────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# Google AI Studio — Gemini 1.5 Pro
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase — PostgreSQL + Storage
# Get from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Resend — Email delivery
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_your_resend_api_key_here

# Email config
RESEND_FROM_EMAIL=nodal@yourdomain.com
NODAL_BASE_URL=http://localhost:3000

# Google OAuth (Gmail API integration)
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Consent screen: External + Testing mode, add demo accounts as Test users,
# scopes gmail.send + openid + email. Authorized JS origins: localhost + Cloud Run URL.
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# Same value as GOOGLE_CLIENT_ID — exposed to the browser for the sign-in flow.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here

# Demo-safe dispatch: when set, ALL department/RTI/RPWD emails go only to this
# inbox (intended recipient tagged in the body). Leave empty for live sending
# to the routing-matrix addresses.
DISPATCH_TEST_INBOX=your_demo_inbox@gmail.com

# Hard ceiling on paid Gemini analyses per day (cost protection). Default 100.
MAX_DAILY_ANALYSES=100

# Shared secret the daily pg_cron job sends in the x-cron-secret header to
# authorize POST /api/reminders (the Day 7/15/30 escalation emails). Must match
# app.settings.cron_secret in the Supabase DB. /api/reminders fails closed if unset.
CRON_SECRET=your_cron_secret_here

