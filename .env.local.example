# ─── NODAL Environment Variables ─────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# Google AI Studio — Gemini 1.5 Pro
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase — PostgreSQL + Storage
# Get from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Resend — Email delivery
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_your_resend_api_key_here

# Email config
RESEND_FROM_EMAIL=nodal@yourdomain.com
NODAL_BASE_URL=http://localhost:3000

# Google OAuth (Gmail API integration)
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

